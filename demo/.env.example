# Smart Account Kit Demo Configuration
# Copy this file to .env and customize as needed

# Stellar Network Configuration
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Uploaded WASM hashes (testnet)
# Smart Account: 1b5f4534a76322da2ad7c745f6900857a6802b0ca79850c35a03561df997785a
# WebAuthn Verifier: e63a030d0f1a1481e36059a4837c433083b33e704c1f9625b7314795b6d72b76
# Ed25519 Verifier: 60e8798db610bdaf3370d39ebda56ee1dc2c15ce1c3a9e28b528bfa24a06b477
# Threshold Policy: cb6c0bd9cd06abba05f924ff4157b41aa1dd3891803c7c93b3b158e20986e592
# Spending Limit Policy: e41b563c4454f5a6742acfa6d44e1ece96d443bb5f40efddd6ed05180210219a
# Weighted Threshold Policy: 7565d0a585254be47001281baef5bbc5d539ccbe1c813196b3c45995a6c15b74
#
# Smart Account Contract (WASM hash uploaded to network)
VITE_ACCOUNT_WASM_HASH=1b5f4534a76322da2ad7c745f6900857a6802b0ca79850c35a03561df997785a

# Optional: use a deployed contract ID instead of a WASM hash when regenerating
# bindings against a specific smart account instance.
VITE_ACCOUNT_CONTRACT_ID=

# Verifier Contracts
VITE_WEBAUTHN_VERIFIER_ADDRESS=CC7EKIHQP3TN4CARQDND6CEOY2UXLWWC2X5GHTD5NLAT7BG5GPZIOM3F
VITE_ED25519_VERIFIER_ADDRESS=CAAVTMCBXEIBPR64EAASKFXERVPYFZA2JYP5A3BG6PESWEFUJX5IHKN4

# Native XLM Token Contract (SAC address)
VITE_NATIVE_TOKEN_CONTRACT=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Policy Contracts
# Threshold and spending-limit are enabled in the default demo.
# Weighted-threshold is optional; set it to expose that policy in the UI.
VITE_THRESHOLD_POLICY_ADDRESS=CB3FATQKCIRIQOCYRUPCQ2KREQ7T4RPKS7EAEOZWPEPUKWEDRVROBCEG
VITE_SPENDING_LIMIT_POLICY_ADDRESS=CABXBYJNZ7IUW4G3D6BND5YCAQF3ASSDMDAOKQQ63UYFSO7WUU2TIP5G
VITE_WEIGHTED_THRESHOLD_POLICY_ADDRESS=CCMZ6X4KM3RC7HXWCZDTH7CMWIJXFPN6HLGKJBM63MCOW2AJ2V5W7YXY

# Fee Sponsoring (optional)
# Relayer proxy URL - transactions are POSTed to this endpoint
# Example: VITE_RELAYER_URL=https://my-relayer-proxy.example.com
VITE_RELAYER_URL=
