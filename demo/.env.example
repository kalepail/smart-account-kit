# Smart Account Kit Demo Configuration
# Copy this file to .env and customize as needed

# Stellar Network Configuration
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart Account Contract (WASM hash uploaded to network)
VITE_ACCOUNT_WASM_HASH=3e51f5b222dec74650f0b33367acb42a41ce497f72639230463070e666abba2c

# Verifier Contracts
VITE_WEBAUTHN_VERIFIER_ADDRESS=CATPTBRWVMH5ZCIKO5HN2F4FMPXVZEXC56RKGHRXCM7EEZGGXK7PICEH
VITE_ED25519_VERIFIER_ADDRESS=CAIKK32K3BZJYTWVTXHZFPIEEDBR6YCVTGPABH4UQUQ4XFA3OLYXG27G

# Native XLM Token Contract (SAC address)
VITE_NATIVE_TOKEN_CONTRACT=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Policy Contracts
# Threshold and spending-limit are enabled in the default demo.
# Weighted-threshold is optional; set it to expose that policy in the UI.
VITE_THRESHOLD_POLICY_ADDRESS=CDDQLFG7CV74QHWPSP6NZIPNBR2PPCMTUVYCJF4P3ONDYHODRFGR7LWC
VITE_SPENDING_LIMIT_POLICY_ADDRESS=CBYLPYZGLQ6JVY2IQ5P23QLQPR3KAMMKMZLNWG6RUUKJDNYGPLVHK7U4
VITE_WEIGHTED_THRESHOLD_POLICY_ADDRESS=

# Fee Sponsoring (optional)
# Relayer proxy URL - transactions are POSTed to this endpoint
# Example: VITE_RELAYER_URL=https://my-relayer-proxy.example.com
VITE_RELAYER_URL=
