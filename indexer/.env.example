# Smart Account Indexer shared configuration
# Copy this file to .env.dev or .env.prod if you want a single place to track
# your database and Goldsky settings.
#
# Wrangler does NOT load this file automatically.
# For local Worker development, copy handler/.dev.vars.example to
# handler/.dev.vars instead. For deployed Workers, use Wrangler secrets.

# PostgreSQL Database (e.g., Neon, Supabase, or self-hosted)
# Used by: Goldsky pipeline sink, Cloudflare Worker secret/local .dev.vars
DATABASE_URL="postgresql://user:password@host:5432/database"

# Individual connection parameters (alternative to DATABASE_URL)
PGHOST="your-db-host.example.com"
PGPORT=5432
PGDATABASE="your_database_name"
PGUSER="your_username"
PGPASSWORD="your_password"

# Goldsky Configuration (for mainnet pipeline)
# Secret name must match the secret configured in Goldsky
GOLDSKY_SECRET_NAME="your_goldsky_secret"

# Goldsky API Key (from your Goldsky dashboard)
GOLDSKY_API_KEY="your_goldsky_api_key"
