# Smart Account Indexer Demo Configuration
# Copy this file to .env and customize as needed

# Stellar Network Configuration
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://mainnet.stellar.validationcloud.io/v1/<api-key>
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Smart Account Indexer URL (Mercury)
# Testnet: https://testnet.mercurydata.app/rest/smart-account-indexer
# Mainnet: https://mainnet.mercurydata.app/rest/smart-account-indexer
VITE_INDEXER_URL=https://testnet.mercurydata.app/rest/smart-account-indexer

# Optional provider token. Sent as Authorization: Bearer <token>.
# Mercury's indexer reads are anonymous, so leave this blank for Mercury today.
# Set it only for a provider that requires one. Vite exposes this value in the
# browser bundle; never use a Mercury account JWT or any other privileged credential.
VITE_INDEXER_AUTH_TOKEN=

# Optional overrides (testnet defaults are baked in). The passphrase / WASM hash /
# WebAuthn verifier are used when authenticating a passkey for discovery.
# VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# VITE_ACCOUNT_WASM_HASH=1b5f4534a76322da2ad7c745f6900857a6802b0ca79850c35a03561df997785a
# VITE_WEBAUTHN_VERIFIER_ADDRESS=CC7EKIHQP3TN4CARQDND6CEOY2UXLWWC2X5GHTD5NLAT7BG5GPZIOM3F

# Known policy contracts. When a viewed rule uses one of these addresses, the demo
# reads its live params via the SDK's typed policy clients (get_threshold /
# get_spending_limit_data). Other policies fall back to the indexer's install_params.
# VITE_THRESHOLD_POLICY_ADDRESS=CB3FATQKCIRIQOCYRUPCQ2KREQ7T4RPKS7EAEOZWPEPUKWEDRVROBCEG
# VITE_SPENDING_LIMIT_POLICY_ADDRESS=CABXBYJNZ7IUW4G3D6BND5YCAQF3ASSDMDAOKQQ63UYFSO7WUU2TIP5G
# VITE_WEIGHTED_THRESHOLD_POLICY_ADDRESS=CCMZ6X4KM3RC7HXWCZDTH7CMWIJXFPN6HLGKJBM63MCOW2AJ2V5W7YXY
