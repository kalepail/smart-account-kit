# Smart Account Indexer Demo Configuration
# Copy this file to .env and customize as needed

# Stellar Network Configuration
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://mainnet.stellar.validationcloud.io/v1/<api-key>
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Smart Account Indexer URL
# Testnet: https://smart-account-indexer.sdf-ecosystem.workers.dev
# Mainnet: https://smart-account-indexer-mainnet.sdf-ecosystem.workers.dev
# Mercury testnet: https://testnet.mercurydata.app/rest/smart-account-indexer
# Mercury mainnet: https://mainnet.mercurydata.app/rest/smart-account-indexer
VITE_INDEXER_URL=https://smart-account-indexer.sdf-ecosystem.workers.dev

# Optional API key or JWT. Sent as Authorization: Bearer <token>.
# Vite exposes this value in the browser bundle; do not use privileged/admin tokens.
VITE_INDEXER_AUTH_TOKEN=
