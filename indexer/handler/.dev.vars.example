# Smart Account Indexer handler local secrets
# Copy to .dev.vars for `wrangler dev`.
#
# For deployed environments, keep using Wrangler secrets instead:
#   wrangler secret put DATABASE_URL
#   wrangler secret put DATABASE_URL --env production

DATABASE_URL="postgresql://user:password@host:5432/database"

# Optional bearer-token gate. Leave unset to run the handler as a public
# reference implementation (the default; /api/credentials stays locked either
# way). When set, every /api/* route requires `Authorization: Bearer <token>`.
#   wrangler secret put INDEXER_AUTH_TOKEN
# INDEXER_AUTH_TOKEN="change-me"
