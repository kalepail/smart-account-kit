{
  "name": "smart-account-kit",
  "version": "0.4.0",
  "description": "TypeScript SDK for deploying and managing OpenZeppelin smart account contracts on Stellar with WebAuthn passkey authentication",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "agent-browser:webauthn": "node scripts/agent-browser-webauthn-helper.mjs",
    "prebuild": "node scripts/sync-version.js",
    "build": "pnpm --filter smart-account-kit-bindings build && tsc",
    "build:all": "./scripts/build.sh",
    "build:bindings": "./scripts/bindings/build.sh",
    "verify:bindings": "bash scripts/bindings/verify.sh",
    "build:demo": "pnpm build && pnpm --filter smart-account-kit-demo build",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist packages/smart-account-kit-bindings/dist",
    "test": "vitest",
    "test:e2e:browser:full": "bash scripts/browser-full-e2e-audit.sh",
    "test:e2e:testnet-passkey:onchain": "SKIP_INDEXER=true bash scripts/testnet-passkey-smoke.sh",
    "test:e2e:testnet-passkey": "bash scripts/testnet-passkey-smoke.sh",
    "release": "./scripts/publish.sh",
    "release:bindings": "./scripts/bindings/publish.sh"
  },
  "keywords": [
    "stellar",
    "soroban",
    "smart-account",
    "webauthn",
    "passkey",
    "wallet",
    "multisig",
    "openzeppelin"
  ],
  "author": "Tyler van der Hoeven <tyler@stellar.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalepail/smart-account-kit"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@stellar/stellar-sdk": "16.0.1",
    "base64url": "^3.0.1",
    "smart-account-kit-bindings": "workspace:*"
  },
  "devDependencies": {
    "@creit-tech/stellar-wallets-kit": "jsr:2.1.0",
    "@types/node": "^25.5.2",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "@creit-tech/stellar-wallets-kit": ">=2.1.0",
    "@stellar/stellar-sdk": ">=15.1.0"
  },
  "peerDependenciesMeta": {
    "@creit-tech/stellar-wallets-kit": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@stellar/stellar-sdk": "$@stellar/stellar-sdk"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
